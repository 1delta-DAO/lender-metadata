{
  "name": "lender-metadata",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "update:dataset": "tsx dist/update-dataset.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "node scripts/patch-abis.cjs"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@1delta/abis": "^0.0.9",
    "@1delta/calldata-sdk": "^0.0.139",
    "@1delta/chain-registry": "^0.0.4",
    "@1delta/data-sdk": "^0.0.19",
    "@1delta/lender-registry": "^0.0.19",
    "@1delta/margin-fetcher": "^0.0.213",
    "@1delta/providers": "^0.0.54",
    "lodash": "^4.17.23",
    "viem": "^2.47.6"
  },
  "overrides": {
    "@1delta/abis": "$@1delta/abis",
    "@1delta/calldata-sdk": "$@1delta/calldata-sdk"
  }
}
